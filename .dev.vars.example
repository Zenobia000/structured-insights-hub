# Cloudflare Workers / TanStack Start 本地測試用環境變數
# 真正的 .dev.vars 已在 .gitignore，本檔只示範格式 — 不放實際 key
#
# 使用方式：
#   1. cp .dev.vars.example .dev.vars
#   2. 填入你自己的 key（從 https://platform.openai.com/api-keys 產）
#   3. 重啟 dev server
#
# 部署到 Cloudflare Workers 時改用 wrangler secret：
#   npx wrangler secret put OPENAI_API_KEY --name tanstack-start-app

# OpenAI API key（用於卡 1/2/4/6/8 的 LLM 語意判定 fallback；空字串時走 hardcoded）
OPENAI_API_KEY=""

# OpenAI model 名（預設 gpt-4o-mini，便宜夠用）
OPENAI_MODEL="gpt-4o-mini"

# IP-based rate limit（每 IP 每分鐘最多幾次 LLM 判定）
LLM_RATE_LIMIT_PER_MIN=10

# IP-based daily cap
LLM_RATE_LIMIT_PER_DAY=1000
